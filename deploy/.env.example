# ============================================================
# Nexy - VPS production env
# ============================================================
# Copy to /opt/studio/nexy/.env on the VPS, chmod 600.
# The nexy-web container reads this file via env_file.

# ── Database (self-hosted on same VPS) ──────────────────────
# Use the Docker service name `studio-postgres` (not the public IP)
# because nexy-web is on the studio_default network.
DATABASE_URL=postgresql://studio:CHANGE_ME@studio-postgres:5432/nexy_db

# ── Auth ────────────────────────────────────────────────────
# HMAC secret for JWT session cookies (`nexy_session`).
# Generate: openssl rand -hex 48
JWT_SECRET=change-me-hex-48-bytes

# ── Public URLs (baked into client bundle at build time) ────
# IMPORTANT: change NEXT_PUBLIC_* before building if you want them
# embedded. For runtime-only changes, they are read from env_file.
NEXT_PUBLIC_APP_URL=https://nexy.life
NEXT_PUBLIC_MINIO_URL=http://173.242.60.76:9000

# ── Object storage (MinIO on same VPS) ──────────────────────
MINIO_ENDPOINT=http://studio-minio:9000
MINIO_PUBLIC_URL=http://173.242.60.76:9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=CHANGE_ME

# ── AI providers ────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
REPLICATE_API_TOKEN=r8_...

# ── Email (Resend - invite + transactional) ─────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@nexy.life

# ── Stripe (premium subscriptions) ──────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# ── CivitAI (optional - scene image generation) ─────────────
CIVITAI_API_TOKEN=
